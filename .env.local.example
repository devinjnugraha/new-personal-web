# Site
NEXT_PUBLIC_SITE_URL=https://devinjnugraha.vercel.app

# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use — swap without code changes
# Recommended for dev: anthropic/claude-haiku-4-5 (cheaper)
# Recommended for prod: anthropic/claude-sonnet-4-5
CHAT_MODEL=anthropic/claude-haiku-4-5

# Generation parameters
# Max tokens in LLM response (default: 1000)
CHAT_MAX_OUTPUT_TOKENS=1000
# Sampling temperature (default: 0.7618)
CHAT_TEMPERATURE=0.7618

# Rate limiting
# Max messages per IP within the window (default: 5)
CHAT_RATE_LIMIT=5
# Rate limit window in seconds (default: 3600 = 1 hour)
CHAT_RATE_WINDOW=3600

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

